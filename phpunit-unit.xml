<phpunit bootstrap="tests/unit/bootstrap.php">
    <testsuites>
        <testsuite name="unit">
            <directory prefix="Test" suffix=".php">./tests/unit/</directory>
        </testsuite>
    </testsuites>

    <coverage processUncoveredFiles="true">
        <include>
            <directory suffix=".php">src</directory>
        </include>
    </coverage>

</phpunit>
